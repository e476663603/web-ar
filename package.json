    "@tarojs/plugin-platform-h5": "3.6.31",
    "@tarojs/react": "3.6.31",
    "@tarojs/runtime": "3.6.31",
    "@tarojs/shared": "3.6.31",
    "@tarojs/taro": "3.6.31",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/runtime": "^7.21.5",
    "@tarojs/webpack5-runner": "3.6.31",
    "@types/react": "^18.2.0",
    "babel-preset-taro": "3.6.31",
    "postcss": "^8.4.18",
