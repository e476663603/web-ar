{
  "name": "web-ar",
  "version": "1.1.0",
  "private": true,
  "description": "WebAR App with Image Tracking and 360 Viewer",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:h5": "taro build --type h5",
    "dev:h5": "npm run build:h5 -- --watch",
    "deploy": "npm run build:h5 && echo 'Build complete! Deploy dist/ folder to your server.'"
